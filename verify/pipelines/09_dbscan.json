{
  "name": "clustering-dbscan (iris)",
  "modules": [
    { "type": "LoadData", "name": "Load", "parameters": { "source": "iris.csv" } },
    { "type": "DBSCAN", "name": "DBSCAN", "parameters": { "eps": 0.8, "min_samples": 5 } },
    { "type": "TrainClusteringModel", "name": "FitDBSCAN", "parameters": { "feature_columns": [] } },
    { "type": "ClusteringData", "name": "AssignClusters", "parameters": {} }
  ],
  "connections": [
    { "fromModuleIndex": 0, "fromPort": "data_out", "toModuleIndex": 2, "toPort": "data_in" },
    { "fromModuleIndex": 1, "fromPort": "model_out", "toModuleIndex": 2, "toPort": "model_in" },
    { "fromModuleIndex": 2, "fromPort": "trained_model_out", "toModuleIndex": 3, "toPort": "model_in" },
    { "fromModuleIndex": 0, "fromPort": "data_out", "toModuleIndex": 3, "toPort": "data_in" }
  ]
}
