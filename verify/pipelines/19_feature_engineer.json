{
  "name": "elston feature engineering (cyclical/interaction/trend) + RandomForest regression",
  "modules": [
    { "type": "LoadData", "name": "Load", "parameters": { "source": "bike_sharing_hourly.csv" } },
    { "type": "FeatureEngineer", "name": "FE", "parameters": { "operations": [ { "type": "cyclical", "column": "hr", "period": 24 }, { "type": "interaction", "columns": ["workingday", "hr"] }, { "type": "trend", "name": "trend_index" } ] } },
    { "type": "SplitData", "name": "Split", "parameters": { "train_size": 0.7, "random_state": 42, "shuffle": "True", "stratify": "False", "stratify_column": null } },
    { "type": "RandomForest", "name": "RF", "parameters": { "model_purpose": "regression", "n_estimators": 40, "criterion": "mse", "max_depth": 16, "max_features": null } },
    { "type": "TrainModel", "name": "Train", "parameters": { "feature_columns": ["hr_sin","hr_cos","workingday_x_hr","trend_index","temp","hum","windspeed","weekday","mnth","season","yr","weathersit"], "label_column": "cnt" } },
    { "type": "ScoreModel", "name": "Score", "parameters": {} },
    { "type": "EvaluateModel", "name": "Eval", "parameters": { "model_type": "regression", "label_column": "cnt", "prediction_column": "Predict", "threshold": 0.5 } }
  ],
  "connections": [
    { "fromModuleIndex": 0, "fromPort": "data_out", "toModuleIndex": 1, "toPort": "data_in" },
    { "fromModuleIndex": 1, "fromPort": "data_out", "toModuleIndex": 2, "toPort": "data_in" },
    { "fromModuleIndex": 2, "fromPort": "train_data_out", "toModuleIndex": 4, "toPort": "data_in" },
    { "fromModuleIndex": 3, "fromPort": "model_out", "toModuleIndex": 4, "toPort": "model_in" },
    { "fromModuleIndex": 4, "fromPort": "trained_model_out", "toModuleIndex": 5, "toPort": "model_in" },
    { "fromModuleIndex": 2, "fromPort": "test_data_out", "toModuleIndex": 5, "toPort": "data_in" },
    { "fromModuleIndex": 5, "fromPort": "scored_data_out", "toModuleIndex": 6, "toPort": "data_in" }
  ]
}
