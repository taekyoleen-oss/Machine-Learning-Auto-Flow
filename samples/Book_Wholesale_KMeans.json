    },
    {
      "fromModuleIndex": 2,
      "fromPort": "trained_model_out",
      "toModuleIndex": 4,
      "toPort": "report_in_model"
    },
    {
      "fromModuleIndex": 3,
      "fromPort": "clustered_data_out",
      "toModuleIndex": 4,
      "toPort": "report_in"
    }
  ]
