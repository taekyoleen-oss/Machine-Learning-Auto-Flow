{
  "name": "book-Ch6 wholesale customers (KMeans, 4 centroids)",
  "modules": [
    {
      "type": "LoadData",
      "name": "Load",
      "parameters": {
        "source": "wholesale_customers.csv"
      },
      "position": {
        "x": 50,
        "y": 50
      }
    },
    {
      "type": "KMeans",
      "name": "KMeans",
      "parameters": {
        "n_clusters": 4,
        "init": "k-means++",
        "n_init": 10,
        "max_iter": 300,
        "random_state": 42
      },
      "position": {
        "x": 50,
        "y": 320
      }
    },
    {
      "type": "TrainClusteringModel",
      "name": "TrainCluster",
      "parameters": {
        "feature_columns": []
      },
      "position": {
        "x": 380,
        "y": 180
      }
    },
    {
      "type": "ClusteringData",
      "name": "AssignClusters",
      "parameters": {},
      "position": {
        "x": 720,
        "y": 180
      }
    }
  ],
  "connections": [
    {
      "fromModuleIndex": 0,
      "fromPort": "data_out",
      "toModuleIndex": 2,
      "toPort": "data_in"
    },
    {
      "fromModuleIndex": 1,
      "fromPort": "model_out",
      "toModuleIndex": 2,
      "toPort": "model_in"
    },
    {
      "fromModuleIndex": 2,
      "fromPort": "trained_model_out",
      "toModuleIndex": 3,
      "toPort": "model_in"
    },
    {
      "fromModuleIndex": 0,
      "fromPort": "data_out",
      "toModuleIndex": 3,
      "toPort": "data_in"
    }
  ]
}