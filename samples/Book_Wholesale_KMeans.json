{
  "name": "book-Ch6 wholesale customers (KMeans, 4 centroids)",
  "modules": [
    {
      "type": "LoadData",
      "name": "Load",
      "parameters": {
        "source": "wholesale_customers.csv"
      },
      "position": {
        "x": 50,
        "y": 50
      }
    },
    {
      "type": "KMeans",
      "name": "KMeans",
      "parameters": {
        "n_clusters": 4,
        "init": "k-means++",
        "n_init": 10,
        "max_iter": 300,
        "random_state": 42
      },
      "position": {
        "x": 50,
        "y": 320
      }
    },
    {
      "type": "TrainClusteringModel",
      "name": "TrainCluster",
      "parameters": {
        "feature_columns": []
      },
      "position": {
        "x": 380,
        "y": 180
      }
    },
    {
      "type": "ClusteringData",
      "name": "AssignClusters",
      "parameters": {},
      "position": {
        "x": 720,
        "y": 180
      }
    },
    {
      "type": "ModelAnalysisReport",
      "name": "모델 분석보고서",
      "parameters": {
        "title": "Wholesale 고객 군집(K-Means) 분석보고서",
        "extra_info": "데이터: Wholesale customers(도매 고객 군집). 모델: K-Means. TrainClusteringModel(군집 모델: k·실루엣·관성)을 report_in_model에, ClusteringData(클러스터 할당 결과)를 report_in에 연결하면 군집 분석 과정·분포를 HTML 보고서로 생성한다(고급 사용자 실행, 키 없으면 결정적 폴백).",
        "extra_pdf_text": "",
        "extra_pdf_name": "",
        "use_web_research": true
      },
      "position": {
        "x": 1050,
        "y": 180
      }
    }
  ],
  "connections": [
    {
      "fromModuleIndex": 0,
      "fromPort": "data_out",
      "toModuleIndex": 2,
      "toPort": "data_in"
    },
    {
      "fromModuleIndex": 1,
      "fromPort": "model_out",
      "toModuleIndex": 2,
      "toPort": "model_in"
    },
    {
      "fromModuleIndex": 2,
      "fromPort": "trained_model_out",
      "toModuleIndex": 3,
      "toPort": "model_in"
    },
    {
      "fromModuleIndex": 0,
      "fromPort": "data_out",
