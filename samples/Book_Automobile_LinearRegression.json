{
  "name": "book-Ch5 automobile price (LinearRegression)",
  "modules": [
    {
      "type": "LoadData",
      "name": "Load",
      "parameters": {
        "source": "imports-85-hdrs.csv"
      },
      "position": {
        "x": 50,
        "y": 50
      }
    },
    {
      "type": "SplitData",
      "name": "Split",
      "parameters": {
        "train_size": 0.75,
        "random_state": 42,
        "shuffle": "True",
        "stratify": "False",
        "stratify_column": null
      },
      "position": {
        "x": 380,
        "y": 50
      }
    },
    {
      "type": "LinearRegression",
      "name": "LinReg",
      "parameters": {
        "model_type": "LinearRegression",
        "alpha": 1,
        "l1_ratio": 0.5,
        "fit_intercept": "True"
      },
      "position": {
        "x": 50,
        "y": 320
      }
    },
    {
      "type": "TrainModel",
      "name": "Train",
      "parameters": {
        "feature_columns": [
          "symboling",
          "wheel-base",
          "length",
          "width",
          "height",
          "curb-weight",
          "engine-size",
          "compression-ratio",
          "city-mpg",
          "highway-mpg"
        ],
        "label_column": "price"
      },
      "position": {
        "x": 380,
        "y": 320
      }
    },
    {
      "type": "ScoreModel",
      "name": "Score",
      "parameters": {},
      "position": {
        "x": 720,
        "y": 320
      }
    },
    {
      "type": "EvaluateModel",
      "name": "Eval",
      "parameters": {
        "model_type": "regression",
        "label_column": "price",
        "prediction_column": "Predict",
        "threshold": 0.5
      },
      "position": {
        "x": 1060,
        "y": 320
      }
    },
    {
      "type": "ModelAnalysisReport",
      "name": "모델 분석보고서",
      "parameters": {
        "title": "Automobile 선형회귀 모델 분석보고서",
        "extra_info": "데이터: Automobile(자동차 가격 회귀). 모델: 선형회귀(LinearRegression). 파이프라인 끝 EvaluateModel 출력을 report_in_eval에 연결하면 회귀 지표(MSE/RMSE/MAE/R²·상대오차)·잔차·개발 과정을 HTML 보고서로 생성한다(고급 사용자 실행, 키 없으면 결정적 폴백).",
        "extra_pdf_text": "",
        "extra_pdf_name": "",
        "use_web_research": true
      },
      "position": {
        "x": 1060,
        "y": 580
      }
    }
  ],
  "connections": [
    {
      "fromModuleIndex": 0,
      "fromPort": "data_out",
      "toModuleIndex": 1,
      "toPort": "data_in"
    },
    {
      "fromModuleIndex": 1,
      "fromPort": "train_data_out",
      "toModuleIndex": 3,
      "toPort": "data_in"
    },
    {
      "fromModuleIndex": 2,
      "fromPort": "model_out",
      "toModuleIndex": 3,
      "toPort": "model_in"
    },
    {
      "fromModuleIndex": 3,
      "fromPort": "trained_model_out",
      "toModuleIndex": 4,
      "toPort": "model_in"
    },
    {
      "fromModuleIndex": 1,
      "fromPort": "test_data_out",
      "toModuleIndex": 4,
      "toPort": "data_in"
    },
    {
      "fromModuleIndex": 4,
      "fromPort": "scored_data_out",
      "toModuleIndex": 5,
      "toPort": "data_in"
    },
    {
      "fromModuleIndex": 5,
      "fromPort": "evaluation_out",
      "toModuleIndex": 6,
      "toPort": "report_in_eval"
    }
  ]
}
