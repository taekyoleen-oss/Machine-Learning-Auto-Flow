{
  "name": "book-Ch3 adult census income (DecisionTree classification)",
  "modules": [
    {
      "type": "LoadData",
      "name": "Load",
      "parameters": {
        "source": "adult.csv"
      },
      "position": {
        "x": 50,
        "y": 50
      }
    },
    {
      "type": "SplitData",
      "name": "Split",
      "parameters": {
        "train_size": 0.8,
        "random_state": 42,
        "shuffle": "True",
        "stratify": "False",
        "stratify_column": null
      },
      "position": {
        "x": 380,
        "y": 50
      }
    },
    {
      "type": "DecisionTree",
      "name": "Tree",
      "parameters": {
        "model_purpose": "classification",
        "criterion": "gini",
        "max_depth": 8,
        "min_samples_split": 2,
        "min_samples_leaf": 1
      },
      "position": {
        "x": 50,
        "y": 320
      }
    },
    {
      "type": "TrainModel",
      "name": "Train",
      "parameters": {
        "feature_columns": [
          "age",
          "fnlwgt",
          "education-num",
          "capital-gain",
          "capital-loss",
          "hours-per-week"
        ],
        "label_column": "income"
      },
      "position": {
        "x": 380,
        "y": 320
      }
    },
    {
      "type": "ScoreModel",
      "name": "Score",
      "parameters": {},
      "position": {
        "x": 720,
        "y": 320
      }
    },
    {
      "type": "EvaluateModel",
      "name": "Eval",
      "parameters": {
        "model_type": "classification",
        "label_column": "income",
        "prediction_column": "Predict",
        "threshold": 0.5
      },
      "position": {
        "x": 1060,
        "y": 320
      }
    },
    {
      "type": "ModelAnalysisReport",
      "name": "모델 분석보고서",
      "parameters": {
        "title": "Adult 소득 분류 모델 분석보고서",
        "extra_info": "데이터: UCI Adult(Census Income), 이진 분류(income >50K 여부). 모델: 의사결정나무(criterion=gini, max_depth=8), 수치형 6개 특성(age·fnlwgt·education-num·capital-gain·capital-loss·hours-per-week). 파이프라인 끝 EvaluateModel 출력을 report_in_eval에 연결하면 개발 과정·지표·해석을 HTML 보고서로 생성한다(고급 사용자 실행, 키 없으면 결정적 폴백).",
        "extra_pdf_text": "",
        "extra_pdf_name": "",
        "use_web_research": true
      },
      "position": {
        "x": 1060,
        "y": 580
      }
    }
  ],
  "connections": [
    {
      "fromModuleIndex": 0,
