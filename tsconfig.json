{
  "compilerOptions": {
    "target": "ES2022",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "module": "ESNext",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "skipLibCheck": true,
    "types": [
      "vite/client"
    ],
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "moduleDetection": "force",
    "allowJs": true,
    "jsx": "react-jsx",
    "paths": {
      "@/*": [
        "./*"
      ]
    },
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "typeRoots": ["./node_modules/@types"]
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "vite.config.ts",
    "server",
    "server/**",
    "verify",
    "verify/**",
    "scripts",
    "scripts/**",
    "_workspace",
    "_workspace/**",
    "_workspace_archive",
    "_workspace_archive/**",
    "temp",
    "temp/**",
    "api",
    "**/api",
    "**/api/**",
    "api/**",
    "pages/api",
    "**/pages/api",
    "**/pages/api/**",
    "pages/api/**",
    "**/api/**/*.ts",
    "**/api/**/*.tsx",
    "**/pages/api/**/*.ts",
    "**/pages/api/**/*.tsx",
    "api/**/*.ts",
    "api/**/*.tsx",
    "pages/api/**/*.ts",
    "pages/api/**/*.tsx",
    ".vercel/api",
    "**/.vercel/api/**"
  ]
}
